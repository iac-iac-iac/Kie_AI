{
  "id": "flux-2/flex-image-to-image",
  "category": "image",
  "display_name": "Flux-2 - Image to Image",
  "api_type": "jobs",
  "create_path": "/api/v1/jobs/createTask",
  "model_field": "flux-2/flex-image-to-image",
  "price_hint": "~15 кр.",
  "estimate_credits": 15,
  "parameters": [
    {
      "name": "prompt",
      "type": "textarea",
      "required": true,
      "max_length": 5000
    },
    {
      "name": "input_urls",
      "type": "image_urls",
      "required": true,
      "max_items": 2
    },
    {
      "name": "aspect_ratio",
      "type": "select",
      "options": [
        "1:1",
        "16:9",
        "9:16",
        "4:3",
        "3:4"
      ],
      "default": "1:1"
    },
    {
      "name": "resolution",
      "type": "select",
      "options": [
        "1K",
        "2K"
      ],
      "default": "1K"
    }
  ],
  "docs_url": "https://docs.kie.ai/market/flux2/flex-image-to-image.md"
}
